# Copy to `.env` and fill in. `.env` is git-ignored.
# Read automatically by `docker compose`.

# ---- Images (CI / deploy) ------------------------------------------------
# Registry namespace and tag for the api/web images. CI sets these when it
# builds & pushes; the deploy host sets them (or inherits from Jenkins) to pull
# the right tag. Left at defaults, `docker compose up --build` builds locally.
REGISTRY=inkaben.se
IMAGE_TAG=latest

# ---- Database ------------------------------------------------------------
POSTGRES_DB=stigvidd
POSTGRES_USER=stigvidd
POSTGRES_PASSWORD=change-me-to-a-strong-secret

# ---- Backend API ---------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Production
# Host port the API is published on (container always listens on 8080).
API_PORT=5265

# ---- Web frontend --------------------------------------------------------
# Host port the web UI is published on.
WEB_PORT=8080
# NOTE: these are baked into the JS bundle at build time. This must be a URL
# the user's BROWSER can reach the API on (not the internal `api` hostname).
# Change any of these -> rebuild the web image: `docker compose up -d --build web`
VITE_API_URL=http://localhost:5265
VITE_OIDC_URL=https://inkaben.se/auth
VITE_OIDC_REALM=stigvidd
VITE_CLIENT_ID=stigvidd-admin
