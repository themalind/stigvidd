# Copy to `.env` and fill in. `.env` is git-ignored.
# Read automatically by `docker compose`.

# ---- Images (CI / deploy) ------------------------------------------------
# Registry namespace and tag for the api/web images. CI sets these when it
# builds & pushes; the deploy host sets them (or inherits from Jenkins) to pull
# the right tag. Left at defaults, `docker compose up --build` builds locally.
REGISTRY=inkaben.se
IMAGE_TAG=latest

# ---- Domains / TLS (Caddy reverse proxy) ---------------------------------
# Each must have a DNS A/AAAA record pointing at THIS host, with ports 80 & 443
# reachable, before Caddy can obtain Let's Encrypt certificates.
WEB_DOMAIN=stigvidd.se
API_DOMAIN=api.stigvidd.se
MEDIA_DOMAIN=media.stigvidd.se
AUTH_DOMAIN=auth.stigvidd.se
# ACME contact address (expiry/renewal notices from Let's Encrypt).
ACME_EMAIL=admin@stigvidd.se
# While testing, use LE staging to avoid rate limits (certs won't be trusted):
#   ACME_CA=https://acme-staging-v02.api.letsencrypt.org/directory
ACME_CA=https://acme-v02.api.letsencrypt.org/directory

# ---- Database ------------------------------------------------------------
POSTGRES_DB=stigvidd
POSTGRES_USER=stigvidd
POSTGRES_PASSWORD=change-me-to-a-strong-secret

# ---- Keycloak (identity provider) ----------------------------------------
# Public issuer URL (served by the proxy at AUTH_DOMAIN). Used by the API and
# web as the OIDC authority; must be the PUBLIC URL, no trailing slash.
KEYCLOAK_URL=https://auth.stigvidd.se
# Keycloak's own database inside the app Postgres instance.
KEYCLOAK_DB=keycloak
# First-boot admin account for the Keycloak master realm (console login).
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=change-me-to-a-strong-secret

# ---- Backend API ---------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Production

# ---- Media / WebDAV ------------------------------------------------------
# Credentials the API uses to upload to the media server (basic auth on writes;
# reads are public). Set both; they must match on api and media.
WEBDAV_USER=stigvidd
WEBDAV_PASSWORD=change-me-to-a-strong-secret
# Public base URL the API hands to clients so they can READ images (the media
# subdomain, served over TLS by the proxy). Keep the trailing slash.
PRESENTABLE_BASE_URL=https://media.stigvidd.se/

# ---- Web frontend --------------------------------------------------------
# Baked into the JS bundle at build time. Now a stable public URL, so the same
# image works on every host (no more per-host rebuilds).
# Change any of these -> rebuild the web image: `docker compose up -d --build web`
VITE_API_URL=https://api.stigvidd.se
VITE_OIDC_URL=https://auth.stigvidd.se
VITE_OIDC_REALM=stigvidd
VITE_CLIENT_ID=stigvidd-admin
