{
  "expo": {
    "name": "stigvidd",
    "slug": "stigvidd",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "scheme": "stigvidd",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f436d9c7-ff9c-4a60-b51f-1aefd5672205"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stigvidd.app",
      "buildNumber": "1",
      "infoPlist": {
        "UIBackgroundModes": ["location"],
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {}
    },
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "backgroundColor": "#68AE82",
        "foregroundImage": "./src/assets/images/android-icon-foreground.png",
        "backgroundImage": "./src/assets/images/android-icon-background.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.stigvidd.app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": ""
    },
    "notification": {
      "androidMode": "collapse",
      "androidCollapsedTitle": "#{unread_notifications} nya aviseringar"
    },
    "plugins": [
      "expo-router",
      "@maplibre/maplibre-react-native",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#68AE82",
          "dark": {
            "backgroundColor": "#68AE82"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./src/assets/images/android-icon-foreground.png",
          "color": "#68AE82"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "$(PRODUCT_NAME) använder din plats för att registrera din vandringsrutt – även när appen är i bakgrunden eller skärmen är släckt – så att hela vandringen spåras korrekt.",
          "locationWhenInUsePermission": "$(PRODUCT_NAME) använder din plats för att visa var du är på kartan och registrera din vandringsrutt medan appen är öppen.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f436d9c7-ff9c-4a60-b51f-1aefd5672205"
      }
    }
  }
}
